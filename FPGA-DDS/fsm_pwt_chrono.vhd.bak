--
--	  Brief: 
--		fsm to test chrono phase tunning word 
--			MEM (32 differents timers)+ Chrono (32bits) + Address (32 position)
--------------------------------------------------------------------------

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

ENTITY fsm_pwt_chrono IS
  port (
		clk_fsmpwt     		: 	IN  std_logic; 
		rst_n_fsmpwt  			: 	IN  std_logic;  
		start_fsmpwt			: 	IN  std_logic;  
		overflow_flag			: 	IN  std_logic;
		ptw_fsm_rdy				:	IN std_logic; -- flag from pwt fsm
		-- Outflags MEM
		rd_en_mem				: 	OUT  std_logic;
		wr_en_mem				:  OUT  std_logic;
		clk_en_mem				: 	OUT  std_logic;
		aclk_mem					:	OUT  std_logic;		
		-- Outflags Chrono		
		count_n_rst				: 	OUT  std_logic;
		count_en					: 	OUT  std_logic;
		count_preload_en		: 	OUT  std_logic;
		-- Outflags address
		address_en				: 	OUT  std_logic;
		address_n_rst			: 	OUT  std_logic;
		fsm_pwt_init			: 	OUT  std_logic -- signal to allow pwt fsm load phase word
  );
END ENTITY fsm_pwt_chrono;
------------------------------------------------
ARCHITECTURE Behavioral OF fsm_pwt_chrono IS
  -- Signals declarations
  TYPE state_type IS (state_Init, state_0, state_1, state_2, state_3, state_4);	-- Enumerated type decl
  SIGNAL state : state_type; 											-- state_type is signal type

BEGIN
state_transition: PROCESS (clk_fsmpwt, rst_n_fsmpwt, start_fsmpwt,overflow_flag) 	--sensitive list
  	-- Variables declarations

	BEGIN
		IF (rst_n_fsmpwt = '0') THEN   			-- asynchronous reset
			state <= state_Init;	
		ELSIF (clk_fsmpwt'EVENT AND clk_fsmpwt='1') THEN -- Change State
			CASE state IS
				WHEN state_Init =>			-- M10K disable
					IF (start_fsmpwt = '0') THEN 
						state <= state_Init;	
					ELSE 
						state <= state_0; 
					END IF;
				WHEN state_0 =>					
						state <= state_1;
				WHEN state_1 =>					-- initiate pwt fsm 		
					IF (ptw_fsm_rdy = '1') THEN 
						state <= state_2;	
					ELSE 
						state <= state_1;
					END IF;
				WHEN state_2 =>					-- OVERFLOW read
					IF (overflow_flag = '1') THEN 
						state <= state_3;	
					ELSE 
						state <= state_2;
					END IF;
				WHEN state_3 =>
						state <= state_4;
				WHEN state_4 =>					
						state <= state_0;						
			END CASE;
		END IF;
	END PROCESS state_transition;
  
  
Output_logic: PROCESS (state)
	BEGIN							
 		CASE state IS
			WHEN state_Init => -- active Rst
				-- Outflags MEM
				aclk_mem					<= '1';
				rd_en_mem				<= '0';							
				wr_en_mem				<= '0';				
				clk_en_mem				<= '0';
				-- Outflags Chrono		
				count_n_rst				<= '0';				
				count_en					<= '0';					
				count_preload_en		<= '0';		
				-- Outflags address
				address_n_rst			<= '0';	
				address_en				<= '0';
				fsm_pwt_init			<= '0';
			WHEN state_0 => 	 -- active mem pre load data in chrono inputs
				-- Outflags MEM
				aclk_mem					<= '0';
				rd_en_mem				<= '1';							
				wr_en_mem				<= '0';				
				clk_en_mem				<= '1';
				-- Outflags Chrono		
				count_n_rst				<= '1';				
				count_en					<= '0';					
				count_preload_en		<= '0';		
				-- Outflags address
				address_n_rst			<= '1';	
				address_en				<= '0';
				fsm_pwt_init			<= '1';				
			WHEN state_1 =>	-- pre load chrono	
				-- Outflags MEM
				aclk_mem					<= '0';
				rd_en_mem				<= '1';							
				wr_en_mem				<= '0';				
				clk_en_mem				<= '0';
				-- Outflags Chrono		
				count_n_rst				<= '1';				
				count_en					<= '1';					
				count_preload_en		<= '1';		
				-- Outflags address
				address_n_rst			<= '1';	
				address_en				<= '0';
				fsm_pwt_init			<= '0';
			WHEN state_2 =>	-- acive chrono counter
				-- Outflags MEM
				aclk_mem					<= '0';
				rd_en_mem				<= '1';							
				wr_en_mem				<= '0';				
				clk_en_mem				<= '0';
				-- Outflags Chrono		
				count_n_rst				<= '1';				
				count_en					<= '1';					
				count_preload_en		<= '0';-- Inactive to count	
				-- Outflags address
				address_n_rst			<= '1';	
				address_en				<= '0';
				fsm_pwt_init			<= '0';				
			WHEN state_3 =>						-- Address Count
				-- Outflags MEM
				aclk_mem					<= '0';
				rd_en_mem				<= '1';							
				wr_en_mem				<= '0';				
				clk_en_mem				<= '0';
				-- Outflags Chrono		
				count_n_rst				<= '0';				
				count_en					<= '0';					
				count_preload_en		<= '0';		
				-- Outflags address
				address_n_rst			<= '1';	
				address_en				<= '1';
				fsm_pwt_init			<= '0';				
			WHEN state_4 =>
				-- Outflags MEM
				aclk_mem					<= '0';
				rd_en_mem				<= '1';							
				wr_en_mem				<= '0';				
				clk_en_mem				<= '1';
				-- Outflags Chrono		
				count_n_rst				<= '1';				
				count_en					<= '0';					
				count_preload_en		<= '0';		
				-- Outflags address
				address_n_rst			<= '1';	
				address_en				<= '0';
				fsm_pwt_init			<= '0';

		END CASE;
	END PROCESS Output_logic; 

END ARCHITECTURE Behavioral;