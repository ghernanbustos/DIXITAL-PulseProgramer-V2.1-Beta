--	  Brief: 
--		fsm to test chrono phase tunning word 
--			MEM + Chrono + Address
--------------------------------------------------------------------------

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

ENTITY fsm_pwt_write IS
  port (
		clk_fsm     		: 	IN  std_logic; -- clk_fsm 50Mhz
		rst_n_fsm   		: 	IN  std_logic; -- External switch
		init_pwt_load		: 	IN  std_logic; -- Push button tu start fsm
		
		-- Address Counter | Mem | fsm timer
		count_address_en 	:	OUT std_logic; 
		
		clk_en_pwtmem		:	OUT std_logic;
		rd_pwtmem			: 	OUT std_logic;
		aclr_pwtmem			: 	OUT std_logic;
		
		ptw_rdy				:	OUT std_logic; 
		ptw_rdy_debug		:	OUT std_logic; 
		
		-- DDS Write Data Control	
		masterRst	 		:	OUT std_logic;	-- dds Master Rst on
		rd_n			 		: 	OUT std_logic; -- Read off
		wd_n			 		:	OUT std_logic;	-- write off
		FSK_BPSK_HOLD		:	OUT std_logic;
		I_O_update			:	OUT std_logic
  );
END ENTITY fsm_pwt_write;
------------------------------------------------
ARCHITECTURE Behavioral OF fsm_pwt_write IS
  -- Signals declarations
  TYPE state_type IS (state_reset, state_1, state_2,state_3,state_4);
  SIGNAL state : state_type; 														 
  
BEGIN
state_transition: PROCESS (clk_fsm, rst_n_fsm, init_pwt_load) 	 
  	-- Variables declarations
	VARIABLE count : INTEGER RANGE 0 TO 1; 				--  
	BEGIN
		IF (rst_n_fsm = '0') THEN   							--  
			state <= state_reset;
			count := 0;			
		ELSIF (clk_fsm'EVENT AND clk_fsm ='1') THEN   				 
			CASE state IS
				WHEN state_reset =>
					IF (init_pwt_load = '1') THEN  
						state <= state_1;	--  
					ELSE 
						state <= state_reset;
					END IF;
				WHEN state_1 =>		-- Enble mem			 
					state <= state_2;  
				WHEN state_2 =>		-- Enble mem			 
					state <= state_3;
				WHEN state_3 =>					
					IF (count=1) THEN count := 0;
						state <= state_4;
					ELSE
						count := count + 1;	
						state <= state_1; 
					END IF;
				WHEN state_4 =>					-- 
					state <= state_reset;					
			END CASE;
		END IF;
	END PROCESS state_transition;
  
  
Output_logic: PROCESS (state)
	BEGIN							
 		CASE state IS
			WHEN state_reset => -- Initial state/reset state
				-- fsm control
				count_address_en 	<= '0';
				clk_en_pwtmem		<= '0';
				aclr_pwtmem			<= '0';
				rd_pwtmem			<= '0';
				ptw_rdy				<= '0';
				ptw_rdy_debug		<= '0';
				--dds control
				masterRst	 	<= '0';	
				rd_n			 	<= '1';  
				wd_n			 	<= '1';	
				FSK_BPSK_HOLD	<= 'Z';	
				I_O_update		<= '0';
			WHEN state_1 => 
				-- fsm control
				count_address_en 	<= '0';
				clk_en_pwtmem		<= '1';	-- mem enable
				aclr_pwtmem			<= '0';
				rd_pwtmem			<= '1';
				ptw_rdy				<= '0';
				ptw_rdy_debug		<= '0';
				--dds control				
				masterRst	 	<= '0';	
				rd_n			 	<= '1';  
				wd_n			 	<= '1';	
				FSK_BPSK_HOLD	<= 'Z';	
				I_O_update		<= '0';
			WHEN state_2 => 
				-- fsm control
				count_address_en 	<= '0'; -- 64 position counter
				clk_en_pwtmem		<= '1'; -- Enable memory
				aclr_pwtmem			<= '0';
				rd_pwtmem			<= '0';
				ptw_rdy				<= '0';
				ptw_rdy_debug		<= '0';	
				--dds control				
				masterRst	 	<= '0';	
				rd_n			 	<= '1';  
				wd_n			 	<= '0';	-- write reg
				FSK_BPSK_HOLD	<= 'Z';	
				I_O_update		<= '0';
			WHEN state_3 => 
				-- fsm control
				count_address_en 	<= '1'; -- 64 position counter
				clk_en_pwtmem		<= '1'; -- Enable memory
				aclr_pwtmem			<= '0';
				rd_pwtmem			<= '0';
				ptw_rdy				<= '0';
				ptw_rdy_debug		<= '0';	
				--dds control				
				masterRst	 	<= '0';	
				rd_n			 	<= '1';  
				wd_n			 	<= '1';	-- write reg
				FSK_BPSK_HOLD	<= 'Z';	
				I_O_update		<= '0';
			WHEN state_4 => -- Avisa a la fsm chrono que corra el timer
				-- fsm control
				count_address_en 	<= '0';
				clk_en_pwtmem		<= '0';
				aclr_pwtmem			<= '0';
				rd_pwtmem			<= '0';
				ptw_rdy				<= '1';
				ptw_rdy_debug		<= '1';
				--dds control				
				masterRst	 	<= '0';	
				rd_n			 	<= '1';  
				wd_n			 	<= '1';	
				FSK_BPSK_HOLD	<= 'Z';	
				I_O_update		<= '1';	-- upadte data	
		END CASE;
	END PROCESS Output_logic; -- Outputs are updated at the end of the process

END ARCHITECTURE Behavioral;