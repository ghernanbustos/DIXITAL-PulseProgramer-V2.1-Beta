LIBRARY ieee;
USE ieee.std_logic_1164.all;
----------------------------------------------
ENTITY ram_mux48b IS
	PORT (	
			-- wr_rd_sel
			data_sel	: IN  STD_LOGIC := '0';
			-- Data In
			data_1	: IN STD_LOGIC_VECTOR(48 DOWNTO 0); 
			data_2	: IN STD_LOGIC_VECTOR(48 DOWNTO 0);
	
			-- OUT PORTS
			data_Out : OUT STD_LOGIC_VECTOR(48 DOWNTO 0)
			);			
END ram_mux48b;

ARCHITECTURE mux3 OF ram_mux48b IS
BEGIN
    PROCESS (data_sel, data_1_a,data_1_b, data_2)
    BEGIN
        CASE data_sel IS
            WHEN '0' =>
                data_Out <= data_1; -- TO COMPLETE 16BIT output
            WHEN '1' =>
                data_Out <= data_2;
            WHEN OTHERS =>
                data_Out <= (others => '0');
        END CASE;
    END PROCESS;
	
 END mux3;