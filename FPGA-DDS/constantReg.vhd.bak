LIBRARY ieee;
USE ieee.std_logic_1164.all;
----------------------------------------------
ENTITY constantReg IS
	PORT (	
			count	: OUT STD_LOGIC_VECTOR(31 DOWNTO 0)
			);			
END constantReg;

ARCHITECTURE regcte OF constantReg IS
BEGIN
    BEGIN
		count <= "11111110100000101000011110111111"; -- 0.5seg
    END PROCESS;
	
 END regcte;