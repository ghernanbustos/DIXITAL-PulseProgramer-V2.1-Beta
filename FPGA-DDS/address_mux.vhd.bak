--	  Brief: 
--			First 6 MSB are used for  
--------------------------------------------------------------------------------

LIBRARY ieee;
USE ieee.std_logic_1164.all;
----------------------------------------------
ENTITY address_mux IS
	PORT (	
			-- sel_fsm
			sel_fsm	: IN  STD_LOGIC_VECTOR(1 DOWNTO 0);
			-- Data In
			data_1	: IN STD_LOGIC_VECTOR(20 DOWNTO 0);
			data_2	: IN STD_LOGIC_VECTOR(20 DOWNTO 0);	
			data_3	: IN STD_LOGIC_VECTOR(20 DOWNTO 0);	
			-- OUT PORTS
			data_Out : OUT STD_LOGIC_VECTOR(20 DOWNTO 0);
			data_Out_db : OUT STD_LOGIC_VECTOR(20 DOWNTO 0)
			);			
END address_mux;

ARCHITECTURE mux3 OF address_mux IS
BEGIN
    PROCESS (sel_fsm, data_1, data_2, data_3)
    BEGIN
        CASE sel_fsm IS
            WHEN "00" =>
                data_Out <= data_1;
            WHEN "01" =>
                data_Out <= data_2;
            WHEN "10" =>
                data_Out <= data_3;
					 data_Out_db <= data_3;
            WHEN OTHERS =>
                data_Out <= (others => '0');
        END CASE;
    END PROCESS;
	
 END mux3;